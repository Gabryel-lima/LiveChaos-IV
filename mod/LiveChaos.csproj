<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{C1A05S1V-L1VE-CH40-5C4-000000000002}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>LiveChaos</RootNamespace>
    <AssemblyName>LiveChaos.net</AssemblyName>
    <!--
      IV-SDK .NET requires .NET Framework 4.8 (4.5+ compatible at runtime).
      The GitHub Actions runner (windows-latest) includes the 4.8 targeting pack.
    -->
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
  </PropertyGroup>

  <!-- ── Debug AnyCPU ──────────────────────────────────────────────────────── -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <!-- ── Release x86 → ../scripts/ ───────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x86'">
    <OutputPath>..\scripts\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <Optimize>true</Optimize>
    <DebugType>pdbonly</DebugType>
    <PlatformTarget>x86</PlatformTarget>
    <LangVersion>Latest</LangVersion>
    <ErrorReport>prompt</ErrorReport>
  </PropertyGroup>

  <ItemGroup>
    <!-- IV-SDK .NET v1.9.1 wrapper — must be in scripts/ (set up by make setup) -->
    <Reference Include="IVSDKDotNetWrapper">
      <HintPath>..\scripts\IVSDKDotNetWrapper.dll</HintPath>
    </Reference>
    <!-- Newtonsoft.Json for JSON deserialization of pipe messages -->
    <Reference Include="Newtonsoft.Json">
      <HintPath>..\scripts\Newtonsoft.Json.dll</HintPath>
    </Reference>
    <Reference Include="System" />
    <Reference Include="System.Numerics">
      <HintPath>/usr/lib/mono/4.5/System.Numerics.dll</HintPath>
    </Reference>
    <Reference Include="System.Numerics.Vectors">
      <HintPath>/usr/lib/mono/4.5/System.Numerics.Vectors.dll</HintPath>
    </Reference>
    <Reference Include="System.Core" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Xml" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Effects.cs" />
    <Compile Include="PipeClient.cs" />
    <Compile Include="HUD.cs" />
    <Compile Include="EffectRunner.cs" />
    <Compile Include="LiveChaos.cs" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
