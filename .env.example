# ─── Integração Twitch ───────────────────────────────────────────────────────
# Obtenha seu token OAuth em: https://twitchapps.com/tmi/
TWITCH_ENABLED=true
TWITCH_TOKEN=oauth:seu_token_aqui
TWITCH_CHANNEL=nome_do_seu_canal

# ─── Integração YouTube ──────────────────────────────────────────────────────
# Crie uma chave de API em: https://console.cloud.google.com/
# Ative "YouTube Data API v3" no projeto.
YOUTUBE_ENABLED=false
YOUTUBE_API_KEY=sua_chave_api_youtube_aqui
YOUTUBE_LIVE_ID=id_do_video_da_live_aqui

# ─── Conexão socket (GTA IV ↔ bot) ───────────────────────────────────────────
GTA_HOST=127.0.0.1
GTA_PORT=9999

# ─── Sistema de votação ───────────────────────────────────────────────────────
VOTE_DURATION=30
VOTE_OPTIONS=3
