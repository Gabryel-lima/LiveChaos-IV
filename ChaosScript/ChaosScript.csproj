<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{C1A05S1V-L1VE-CH40-S1V4-000000000001}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>LiveChaos</RootNamespace>
    <AssemblyName>LiveChaos.net</AssemblyName>
    <!--
      GTA IV + ScriptHookDotNet exigem .NET 4.0 ou 3.5.
      NÃO altere para versões superiores.
    -->
    <TargetFrameworkVersion>v4.5</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
  </PropertyGroup>

  <!-- ── Debug AnyCPU ─────────────────────────────────────────── -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <!-- ── Release x86 → ../scripts/ (relativo — padrão portátil) ─────────── -->
  <!-- Usuários Windows: sobrescreva OutputPath nas propriedades do VS ou passe -->
  <!--   /p:OutputPath="C:\...\GTAIV\scripts\" ao msbuild para deploy direto.  -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x86'">
    <OutputPath>..\scripts\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <Optimize>true</Optimize>
    <DebugType>pdbonly</DebugType>
    <PlatformTarget>x86</PlatformTarget>
    <LangVersion>Latest</LangVersion>
    <ErrorReport>prompt</ErrorReport>
  </PropertyGroup>

  <ItemGroup>
    <!--
      IVSDKDotNetWrapper.dll — API IV-SDK .NET v1.9.1
      O loader IVSDKDotNet.asi deve estar na raiz do GTA IV.
    -->
    <Reference Include="IVSDKDotNetWrapper">
      <HintPath>..\scripts\IVSDKDotNetWrapper.dll</HintPath>
    </Reference>
    <Reference Include="System" />
    <Reference Include="System.Numerics">
      <HintPath>/usr/lib/mono/4.5/System.Numerics.dll</HintPath>
    </Reference>
    <Reference Include="System.Numerics.Vectors">
      <HintPath>/usr/lib/mono/4.5/System.Numerics.Vectors.dll</HintPath>
    </Reference>
    <Reference Include="System.Core" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Xml" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="ChaosScript.cs" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
